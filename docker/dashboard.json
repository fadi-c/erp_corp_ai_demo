{
  "title": "Django + Celery Observability",
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "row",
      "title": "Django HTTP",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests per second",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_total_by_method_total{job=\"backend\"}[1m])) by (method)",
          "legendFormat": "{{method}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Responses by status",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{job=\"backend\"}[1m])) by (status)",
          "legendFormat": "status {{status}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p50 / p95",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5,sum(rate(django_http_requests_latency_including_middlewares_seconds_bucket{job=\"backend\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95,sum(rate(django_http_requests_latency_including_middlewares_seconds_bucket{job=\"backend\"}[1m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Latency by view",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_latency_seconds_by_view_method_sum{job=\"backend\"}[1m])) by (view)",
          "legendFormat": "{{view}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Django Database",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "DB Queries per second",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(django_db_execute_total{job=\"backend\"}[1m])",
          "legendFormat": "queries/s"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "DB Query latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95,sum(rate(django_db_query_duration_seconds_bucket{job=\"backend\"}[1m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "stat",
      "title": "DB connections",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "django_db_new_connections_total{job=\"backend\"}",
          "legendFormat": "connections"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 6,
        "h": 6
      }
    },
    {
      "type": "row",
      "title": "HTTP Payload",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Request body size p95",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95,sum(rate(django_http_requests_body_total_bytes_bucket{job=\"backend\"}[1m])) by (le))",
          "legendFormat": "request p95"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Response body size p95",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95,sum(rate(django_http_responses_body_total_bytes_bucket{job=\"backend\"}[1m])) by (le))",
          "legendFormat": "response p95"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 33,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Custom Application Metrics",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Missing Invoice Embeddings",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "missing_invoice_embeddings_total{job=\"backend\"}",
          "legendFormat": "pid {{pid}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "row",
      "title": "Celery Worker",
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Worker scrape health",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "up{job=\"celery_worker\"}",
          "legendFormat": "worker up"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 51,
        "w": 12,
        "h": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Worker metrics activity",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(scrape_samples_post_metric_relabeling{job=\"celery_worker\"}[1m])",
          "legendFormat": "samples"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 51,
        "w": 12,
        "h": 6
      }
    },
    {
      "type": "row",
      "title": "Celery Beat",
      "gridPos": {
        "x": 0,
        "y": 57,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Beat scrape health",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "up{job=\"celery_beat\"}",
          "legendFormat": "beat up"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 58,
        "w": 12,
        "h": 6
      }
    }
  ]
}