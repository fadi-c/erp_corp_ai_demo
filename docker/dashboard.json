{
  "title": "ERP AI Observability",
  "uid": "erp-ai-observability",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [

    {
      "type": "stat",
      "title": "HTTP Requests / sec",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(django_http_requests_before_middlewares_total[1m])",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "HTTP Error Rate %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[1m])) / sum(rate(django_http_responses_total_by_status_total[1m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },

    {
      "type": "stat",
      "title": "Missing Invoice Embeddings",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "missing_invoice_embeddings_total",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Celery Tasks / sec",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(celery_task_total[1m])",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "API Requests by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total[1m])) by (endpoint)",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "API Latency P95",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_latency_seconds_bucket[5m])) by (le, endpoint))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Django Request Latency P95",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_including_middlewares_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "HTTP Responses by Status",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total[1m])) by (status)",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Celery Tasks Success vs Failure",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(celery_task_total[1m])) by (status)",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Celery Task Duration P95",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket[5m])) by (le, task_name))",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Process CPU Usage",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },

    {
      "type": "timeseries",
      "title": "Python GC Collections",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(python_gc_collections_total[5m])",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Open File Descriptors",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_open_fds",
          "refId": "A"
        }
      ]
    }

  ]
}